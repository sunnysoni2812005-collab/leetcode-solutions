class Solution:
    def maxAbsoluteSum(self, nums: list[int]) -> int:
        max_sum = 0
        min_sum = 0
        
        current_max = 0
        current_min = 0
        
        for x in nums:
            current_max = current_max + x
            current_min = current_min + x
            
            if current_max < 0:
                current_max = 0
                
            if current_min > 0:
                current_min = 0
                
            if current_max > max_sum:
                max_sum = current_max
                
            if current_min < min_sum:
                min_sum = current_min
                
        return max(max_sum, abs(min_sum))
