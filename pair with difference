class Solution:
    def findPair(self, arr, x):

        if x == 0:
            freq = {}

            for num in arr:
                freq[num] = freq.get(num, 0) + 1

                if freq[num] >= 2:
                    return True

            return False

        s = set(arr)

        for num in arr:
            if num + x in s:
                return True

        return False
