class Solution:
    def check(self, root):
        self.leafLevel = -1

        def dfs(node, level):
            if not node:
                return True

            # Leaf node
            if not node.left and not node.right:
                if self.leafLevel == -1:
                    self.leafLevel = level
                    return True
                return self.leafLevel == level

            return dfs(node.left, level + 1) and dfs(node.right, level + 1)

        return dfs(root, 0)
