t = int(input())

for _ in range(t):
    n = int(input())
    arr = list(map(int, input().split()))

    ones = sum(x % 2 for x in arr)
    zeros = n - ones

    if n % 2 == 1:
        print(1)
    else:
        if ones % 2 == 0 and zeros % 2 == 0:
            print(1)
        else:
            print(0)
