class Solution:
    def sumK(self, root, k):
        prefix = {0: 1}
        self.ans = 0

        def dfs(node, curr_sum):
            if not node:
                return

            curr_sum += node.data

            self.ans += prefix.get(curr_sum - k, 0)

            prefix[curr_sum] = prefix.get(curr_sum, 0) + 1

            dfs(node.left, curr_sum)
            dfs(node.right, curr_sum)

            prefix[curr_sum] -= 1

        dfs(root, 0)
        return self.ans
