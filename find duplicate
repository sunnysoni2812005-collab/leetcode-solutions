class Solution:
    def findDuplicate(self, nums: List[int]):

        slow = nums[0]
        fast = nums[0]

        # Phase 1: cycle find karo
        while True:
            slow = nums[slow]
            fast = nums[nums[fast]]

            if slow == fast:
                break

        # Phase 2: cycle ka start find karo
        slow = nums[0]

        while slow != fast:
            slow = nums[slow]
            fast = nums[fast]

        return slow
