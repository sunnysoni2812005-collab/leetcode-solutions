from collections import deque

class Solution:
    def openLock(self, deadends, target):

        dead = set(deadends)

        # Starting state hi dead hai
        if "0000" in dead:
            return -1

        queue = deque()
        queue.append(("0000", 0))

        visited = set()
        visited.add("0000")

        while queue:

            state, moves = queue.popleft()

            # Target mil gaya
            if state == target:
                return moves

            # Har wheel ghumao
            for i in range(4):

                digit = int(state[i])

                # +1 aur -1
                for change in (-1, 1):

                    new_digit = (digit + change) % 10

                    new_state = (
                        state[:i]
                        + str(new_digit)
                        + state[i + 1:]
                    )

                    if new_state not in dead and new_state not in visited:

                        visited.add(new_state)
                        queue.append((new_state, moves + 1))

        return -1
