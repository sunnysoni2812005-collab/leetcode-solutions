from collections import defaultdict

t = int(input())

for _ in range(t):

    n = int(input())

    arr = list(map(int, input().split()))

    freq = defaultdict(int)

    for num in arr:
        msb = num.bit_length() - 1
        freq[msb] += 1

    total_pairs = n * (n - 1) // 2

    bad_pairs = 0

    for cnt in freq.values():
        bad_pairs += cnt * (cnt - 1) // 2

    print(total_pairs - bad_pairs)
