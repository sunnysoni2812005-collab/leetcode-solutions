from bisect import bisect_right

class Solution:
    def kthSmallest(self, mat, k):

        n = len(mat)

        low = mat[0][0]
        high = mat[n-1][n-1]

        while low < high:

            mid = (low + high) // 2

            count = 0

            for row in mat:
                count += bisect_right(row, mid)

            if count < k:
                low = mid + 1
            else:
                high = mid

        return low
