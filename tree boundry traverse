class Solution:
    def isLeaf(self, node):
        return node.left is None and node.right is None

    def addLeftBoundary(self, node, ans):
        curr = node.left

        while curr:
            if not self.isLeaf(curr):
                ans.append(curr.data)

            if curr.left:
                curr = curr.left
            else:
                curr = curr.right

    def addLeaves(self, node, ans):
        if node is None:
            return

        if self.isLeaf(node):
            ans.append(node.data)
            return

        self.addLeaves(node.left, ans)
        self.addLeaves(node.right, ans)

    def addRightBoundary(self, node, ans):
        curr = node.right
        temp = []

        while curr:
            if not self.isLeaf(curr):
                temp.append(curr.data)

            if curr.right:
                curr = curr.right
            else:
                curr = curr.left

        while temp:
            ans.append(temp.pop())

    def boundaryTraversal(self, root):
        if root is None:
            return []

        if self.isLeaf(root):
            return [root.data]

        ans = [root.data]

        self.addLeftBoundary(root, ans)
        self.addLeaves(root, ans)
        self.addRightBoundary(root, ans)

        return ans
