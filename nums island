class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:

        rows = len(grid)
        cols = len(grid[0])

        def dfs(r, c):

            # Grid ke bahar chale gaye
            if r < 0 or c < 0 or r >= rows or c >= cols:
                return

            # Water ya already visited
            if grid[r][c] == "0":
                return

            # Current land ko visited mark kar do
            grid[r][c] = "0"

            # 4 directions me jao
            dfs(r + 1, c)   # Down
            dfs(r - 1, c)   # Up
            dfs(r, c + 1)   # Right
            dfs(r, c - 1)   # Left

        islands = 0

        # Puri grid traverse karo
        for i in range(rows):
            for j in range(cols):

                # Naya island mila
                if grid[i][j] == "1":
                    islands += 1
                    dfs(i, j)

        return islands
