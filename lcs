class Solution:

    def lcs(self, s1, s2):

        def solve(i,j):

            if i==len(s1) or j==len(s2):
                return 0

            if s1[i]==s2[j]:
                return 1+solve(i+1,j+1)

            return max(

                solve(i+1,j),

                solve(i,j+1)

            )

        return solve(0,0)
