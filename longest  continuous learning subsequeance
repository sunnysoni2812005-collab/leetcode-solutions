class Solution(object):
    def findLengthOfLCIS(self, nums):

        current = 1
        max_len = 1

        for i in range(1, len(nums)):

            if nums[i] > nums[i - 1]:
                current += 1
            else:
                current = 1

            max_len = max(max_len, current)

        return max_len
