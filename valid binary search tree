class Solution:
    def isValidBST(self, root):

        if not root:
            return True

        if root.left and root.left.val >= root.val:
            return False

        elif root.right and root.right.val <= root.val:
            return False

        else:
            return (self.isValidBST(root.left) and
                    self.isValidBST(root.right))
